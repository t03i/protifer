{
  "__comment": "protifer starter overview dashboard. Import via Grafana Cloud → Dashboards → New → Import, then pick the stack Prometheus data source ($datasource). Versioned here as the source of truth; UI edits should be exported back to this file.",
  "title": "protifer — Overview",
  "uid": "protifer-overview",
  "tags": ["protifer"],
  "schemaVersion": 39,
  "timezone": "browser",
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "label": "Data source"
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Gateway",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1
    },
    {
      "type": "timeseries",
      "title": "HTTP request rate by status",
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_requests_total{app=\"protifer\"}[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "5xx error rate",
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{app=\"protifer\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{app=\"protifer\"}[5m])), 1)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP latency p95 (s)",
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{app=\"protifer\"}[5m])))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "GPU / Triton",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 5
    },
    {
      "type": "timeseries",
      "title": "GPU utilization (%)",
      "id": 6,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 },
        "overrides": []
      },
      "targets": [
        {
          "expr": "avg(nv_gpu_utilization{app=\"protifer\"})",
          "legendFormat": "gpu util",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Triton inference success vs failure (/s)",
      "id": 7,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(nv_inference_request_success{app=\"protifer\"}[5m]))",
          "legendFormat": "success",
          "refId": "A"
        },
        {
          "expr": "sum(rate(nv_inference_request_failure{app=\"protifer\"}[5m]))",
          "legendFormat": "failure",
          "refId": "B"
        }
      ]
    },
    {
      "type": "row",
      "title": "Job pipeline",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 8
    },
    {
      "type": "timeseries",
      "title": "Queue depth by queue & state",
      "id": 9,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (queue, state) (bullmq_queue_jobs{app=\"protifer\"})",
          "legendFormat": "{{queue}} / {{state}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Prediction p95 end-to-end latency (s)",
      "id": 10,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(bullmq_job_total_duration_seconds_bucket{app=\"protifer\",queue=\"prediction\"}[15m])))",
          "legendFormat": "prediction p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(bullmq_job_wait_duration_seconds_bucket{app=\"protifer\",queue=\"prediction\"}[15m])))",
          "legendFormat": "wait p95",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Job failures by reason class (/s)",
      "id": 11,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (reason_class) (rate(bullmq_job_failures_total{app=\"protifer\"}[5m]))",
          "legendFormat": "{{reason_class}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Stale waiting-children (FAIL-04)",
      "id": 12,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 27 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        { "expr": "bullmq_stale_children_jobs{app=\"protifer\"}", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Stalled jobs (5m)",
      "id": 13,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 27 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (queue) (increase(bullmq_stalled_total{app=\"protifer\"}[5m]))",
          "legendFormat": "{{queue}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Storage",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "id": 14
    },
    {
      "type": "gauge",
      "title": "Garage data volume used (%)",
      "id": 15,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "1 - garage_local_disk_avail{app=\"protifer\",volume=\"data\"} / garage_local_disk_total{app=\"protifer\",volume=\"data\"}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Alloy remote-write sample failures (/s)",
      "id": 16,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(prometheus_remote_write_samples_failed_total{app=\"protifer\"}[5m]))",
          "legendFormat": "failed samples",
          "refId": "A"
        }
      ]
    }
  ]
}
