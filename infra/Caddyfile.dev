{
  admin off
}

:80 {
  handle /api/auth/* {
    reverse_proxy api-gateway:3001
  }

  handle /v1/* {
    reverse_proxy api-gateway:3001
  }

  handle /docs {
    reverse_proxy api-gateway:3001
  }
  handle /openapi.json {
    reverse_proxy api-gateway:3001
  }
  handle /health {
    reverse_proxy api-gateway:3001
  }

  handle /admin/* {
    reverse_proxy api-gateway:3001
  }
}
