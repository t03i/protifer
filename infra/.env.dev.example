# Copy to infra/.env.dev and fill in real values.
# GitHub credentials are already set in infra/.env.dev.
# Migrations run automatically via the 'migrate' compose service on every `docker compose up`.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Persistent dev-time API key for hitting /v1/* without browser sign-in.
# Mint via scripts/mint-key.ts; send as `Authorization: Bearer ${PROTIFER_DEV_API_KEY}`.
PROTIFER_DEV_API_KEY=

# Bearer-token API keys for load-test runs (CI injects from secrets).
LOAD_TEST_FREE_BEARER=
LOAD_TEST_PRO_BEARER=

# P3-01: active-jobs ZSET reconciliation loop. Safe defaults; set interval to 0 to disable.
# JOB_CLEANUP_RECONCILE_INTERVAL_MS=60000
# JOB_CLEANUP_LOCK_TTL_MS=30000

# --- Request shedding (admission controller) ---------------------------------
# Protects the embedding queue from aggregate overload. All vars are optional;
# defaults are listed. Set SHED_ENABLED=false to disable the controller
# entirely (middleware becomes a pass-through; no Redis state touched).
# SHED_ENABLED=true
# SHED_MODE=shadow                    # shadow | enforce — shadow records but admits
# SHED_ALPHA=0.2                      # EWMA smoothing factor [0..1]
# SHED_STALENESS_SECONDS=60           # no completion for this long + pending>0 → UPSTREAM_DOWN
# SHED_SLO_FREE_SECONDS=30            # shed free if estimated wait > 30s
# SHED_SLO_PRO_SECONDS=120            # shed pro if estimated wait > 120s
# SHED_SLO_ENTERPRISE_SECONDS=0       # 0 disables the SLO check for this plan
# SHED_INITIAL_RESIDUES_PER_SECOND=2000   # EWMA seed before the first completion
# SHED_RETRY_JITTER_FRACTION=0.3      # ±15% jitter around Retry-After (fraction / 2)
# PLAN_PRIORITY_FREE=3                # BullMQ priority (lower = drained first)
# PLAN_PRIORITY_PRO=2
# PLAN_PRIORITY_ENTERPRISE=1

# Object-store backend: s3 (Garage, default) or filesystem.
# filesystem needs no Garage container — set STORAGE_PATH to a shared dir mounted across
# api-gateway + workers, and optionally STORAGE_MAX_BYTES to cap the disk budget
# (coldest-first eviction; the cache is immutable + re-derivable). See docs/ops/storage-relocation.md.
# STORAGE_DRIVER=filesystem
# STORAGE_PATH=/data/objects
# STORAGE_MAX_BYTES=0

# Garage cluster secret + admin token.
# Dev: intentionally omitted — Garage uses the hardcoded TOML defaults (garage.toml) and
# NODE_ENV != production so assertProductionConfig() does not fire. Prod: set via .env.prod.
# GARAGE_RPC_SECRET=
# GARAGE_ADMIN_TOKEN=

# Better Stack uptime monitoring (SPA secondary signal). Leave unset in dev — hook is a no-op.
# VITE_STATUS_PAGE_URL=https://status.example.com
# VITE_STATUS_API_URL=https://status.example.com/api/v2/status
