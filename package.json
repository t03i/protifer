{
  "name": "protifer",
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/*",
    "services/*",
    "apps/*",
    "infra/*",
    "tests/*",
    "scripts"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:web": "bun run --filter @protifer/web dev",
    "key": "bun --cwd services/api-gateway run ops-key",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test --filter=!@protifer/backend-e2e",
    "test:int": "turbo run test:int",
    "check:demo-artifacts": "bun scripts/check-demo-artifacts-fresh.ts",
    "generate:demo-artifacts": "bun scripts/generate-demo-artifacts.ts",
    "format": "bunx prettier --check .",
    "format:fix": "bunx prettier --write .",
    "clean": "turbo run clean && rm -rf node_modules",
    "postinstall": "husky",
    "flags:lint": "bun scripts/flags-lint.ts",
    "flags:list": "bun scripts/flags-list.ts"
  },
  "devDependencies": {
    "@protifer/eslint-config": "workspace:*",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.21"
  }
}
