{
  "extends": "../../tsconfig.base.json",
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "eslint.config.js",
    "prettier.config.js",
    "vite.config.js"
  ],
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": { "#/*": ["./src/*"] },
    // Stricter than tsconfig.base.json: catches dead props/handler args in components
    "noUnusedParameters": true,
    "noUncheckedSideEffectImports": true
  }
}
